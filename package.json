{
  "name": "randevusistem-root",
  "version": "1.0.0",
  "description": "Full-stack Randevu Appointment System",
  "private": true,
  "scripts": {
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install",
    "install:all": "npm run install:server && npm run install:client",
    "build:client": "cd client && npm run build",
    "start": "cd server && node server.js",
    "deploy": "pm2 restart ecosystem.config.js || pm2 start ecosystem.config.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
